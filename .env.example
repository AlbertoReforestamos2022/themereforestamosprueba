# =============================================================================
# Reforestamos México - Environment Configuration
# =============================================================================
# Copy this file to .env, .env.staging, or .env.production and fill in values.
# NEVER commit actual .env files to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
APP_ENV=development
# Options: development, staging, production

# -----------------------------------------------------------------------------
# WordPress
# -----------------------------------------------------------------------------
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_NAME=reforestamos_dev
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PREFIX=wp_

# -----------------------------------------------------------------------------
# Deployment - Staging
# -----------------------------------------------------------------------------
STAGING_HOST=staging.reforestamos.org
STAGING_USER=deploy
STAGING_PATH=/var/www/staging
STAGING_URL=https://staging.reforestamos.org

# -----------------------------------------------------------------------------
# Deployment - Production
# -----------------------------------------------------------------------------
PRODUCTION_HOST=reforestamos.org
PRODUCTION_USER=deploy
PRODUCTION_PATH=/var/www/production
PRODUCTION_URL=https://reforestamos.org
PRODUCTION_DB_NAME=reforestamos_prod

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@reforestamos.org
SMTP_FROM_NAME=Reforestamos México

# -----------------------------------------------------------------------------
# Google Maps / Leaflet
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups
