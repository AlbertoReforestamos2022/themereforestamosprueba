{
    "name": "reforestamos/composer",
    "description": "genrador JSON para la traducción de las notas del sitio web",
    "type": "library",
    "require": {
        "deeplcom/deepl-php": "^1.8",
        "voku/simple_html_dom": "^4.8",
        "symfony/http-client": "^6.4",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },
    "authors": [
        {
            "name": "Reforestamos México, A.C.",
            "email": "contacto@reforestamos.org"
        }
    ],
    "scripts": {
        "test": "phpunit",
        "test:theme": "phpunit --testsuite 'Theme Tests'",
        "test:core": "phpunit --testsuite 'Core Plugin Tests'",
        "test:micrositios": "phpunit --testsuite 'Micrositios Plugin Tests'",
        "test:comunicacion": "phpunit --testsuite 'Comunicacion Plugin Tests'",
        "test:empresas": "phpunit --testsuite 'Empresas Plugin Tests'",
        "test:migration": "phpunit --testsuite 'Migration System Tests'",
        "lint:php": "phpcs",
        "lint:php:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
