{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "reforestamos/logos-aliados",
  "title": "Logos Aliados",
  "category": "reforestamos",
  "icon": "grid-view",
  "description": "Grid de logos de aliados con efectos hover y enlaces opcionales",
  "keywords": ["logos", "aliados", "partners", "grid", "empresas"],
  "textdomain": "reforestamos",
  "attributes": {
    "logos": {
      "type": "array",
      "default": []
    },
    "columns": {
      "type": "number",
      "default": 4
    },
    "linkable": {
      "type": "boolean",
      "default": true
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.scss"
}
