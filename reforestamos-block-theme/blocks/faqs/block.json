{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "reforestamos/faqs",
  "title": "FAQs",
  "category": "reforestamos",
  "icon": "editor-help",
  "description": "Acordeón de preguntas frecuentes con Bootstrap 5",
  "keywords": ["faq", "accordion", "questions", "preguntas"],
  "textdomain": "reforestamos",
  "attributes": {
    "faqs": {
      "type": "array",
      "default": []
    },
    "openFirst": {
      "type": "boolean",
      "default": true
    },
    "allowMultiple": {
      "type": "boolean",
      "default": false
    },
    "accordionStyle": {
      "type": "string",
      "default": "default"
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.scss"
}
