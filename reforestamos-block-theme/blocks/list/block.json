{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "reforestamos/list",
  "title": "Lista Personalizada",
  "category": "reforestamos",
  "icon": "list-view",
  "description": "Lista personalizada con iconos y diferentes estilos",
  "keywords": ["list", "lista", "icons", "iconos"],
  "textdomain": "reforestamos",
  "attributes": {
    "items": {
      "type": "array",
      "default": []
    },
    "icon": {
      "type": "string",
      "default": "check"
    },
    "listStyle": {
      "type": "string",
      "default": "default"
    },
    "iconColor": {
      "type": "string",
      "default": "primary"
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "anchor": true,
    "spacing": {
      "padding": true,
      "margin": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.scss"
}
