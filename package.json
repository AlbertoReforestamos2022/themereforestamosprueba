    "format": "prettier --write \"reforestamos-block-theme/src/**/*.{js,scss}\" \"reforestamos-block-theme/blocks/**/*.{js,scss}\" \"reforestamos-core/**/*.js\" \"reforestamos-micrositios/**/*.js\" \"reforestamos-comunicacion/**/*.js\" \"reforestamos-empresas/**/*.js\"",
    "format:check": "prettier --check \"reforestamos-block-theme/src/**/*.{js,scss}\" \"reforestamos-block-theme/blocks/**/*.{js,scss}\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bootstrap": "^5.2.3",
    "bootstrap-icons": "^1.11.3"
  },
  "description": "",
  "devDependencies": {
    "@wordpress/eslint-plugin": "^24.3.0",
    "@wordpress/prettier-config": "^4.41.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ],
    "*.php": [
      "vendor/bin/phpcs --report=summary"
    ]
  }
