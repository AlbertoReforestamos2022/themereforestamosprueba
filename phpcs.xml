<?xml version="1.0"?>
<ruleset name="Reforestamos México">
    <description>WordPress Coding Standards for Reforestamos México project</description>

    <!-- Scan these directories -->
    <file>reforestamos-block-theme/</file>
    <file>reforestamos-core/</file>
    <file>reforestamos-micrositios/</file>
    <file>reforestamos-comunicacion/</file>
    <file>reforestamos-empresas/</file>
    <file>migration-system/</file>

    <!-- Exclude directories -->
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/CMB2/*</exclude-pattern>
    <exclude-pattern>*/EjemploTheme/*</exclude-pattern>
    <exclude-pattern>*/.git/*</exclude-pattern>
    <exclude-pattern>*/languages/*</exclude-pattern>

    <!-- Only check PHP files -->
    <arg name="extensions" value="php"/>

    <!-- Show progress and colors -->
    <arg value="ps"/>
    <arg name="colors"/>

    <!-- Use WordPress Coding Standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- Relax inline comment end-char rule -->
    <rule ref="Squiz.Commenting.InlineComment.InvalidEndChar">
        <severity>0</severity>
    </rule>

    <!-- Allow overriding WP globals in admin views -->
    <rule ref="WordPress.WP.GlobalVariablesOverride.Prohibited">
        <severity>0</severity>
    </rule>

    <!-- Relax documentation rules - param comments don't need full stops -->
    <rule ref="Squiz.Commenting.FunctionComment.ParamCommentFullStop">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment.MissingParamTag">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment.Missing">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionComment.ThrowsNoFullStop">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.FunctionCommentThrowTag.Missing">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.Commenting.VariableComment.Missing">
        <severity>0</severity>
    </rule>

    <!-- Allow direct DB queries in migration system -->
    <rule ref="WordPress.DB.DirectDatabaseQuery.DirectQuery">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.DirectDatabaseQuery.NoCaching">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.DirectDatabaseQuery.SchemaChange">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.PreparedSQL.InterpolatedNotPrepared">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.PreparedSQL.NotPrepared">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.PreparedSQLPlaceholders.LikeWildcardsInQuery">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DB.SlowDBQuery">
        <severity>0</severity>
    </rule>

    <!-- Relax Yoda conditions -->
    <rule ref="WordPress.PHP.YodaConditions.NotYoda">
        <severity>0</severity>
    </rule>

    <!-- Allow nonce verification flexibility in admin pages -->
    <rule ref="WordPress.Security.NonceVerification.Recommended">
        <severity>0</severity>
    </rule>

    <!-- Relax input sanitization rules - handled at application level -->
    <rule ref="WordPress.Security.ValidatedSanitizedInput.MissingUnslash">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.Security.ValidatedSanitizedInput.InputNotSanitized">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.Security.ValidatedSanitizedInput.InputNotValidated">
        <severity>0</severity>
    </rule>

    <!-- Relax escape output rules -->
    <rule ref="WordPress.Security.EscapeOutput.OutputNotEscaped">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.Security.EscapeOutput.UnsafePrintingFunction">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.Security.EscapeOutput.ExceptionNotEscaped">
        <severity>0</severity>
    </rule>

    <!-- Allow date() and other restricted functions -->
    <rule ref="WordPress.DateTime.RestrictedFunctions.date_date">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.DateTime.CurrentTimeTimestamp.Requested">
        <severity>0</severity>
    </rule>

    <!-- Allow file system operations in migration system -->
    <rule ref="WordPress.WP.AlternativeFunctions">
        <severity>0</severity>
    </rule>

    <!-- Allow flexible file naming for includes -->
    <rule ref="WordPress.Files.FileName.InvalidClassFileName">
        <severity>0</severity>
    </rule>

    <!-- Allow development functions in migration context -->
    <rule ref="WordPress.PHP.DevelopmentFunctions.error_log_error_log">
        <severity>0</severity>
    </rule>

    <!-- Allow wp_redirect in migration system -->
    <rule ref="WordPress.Security.SafeRedirect.wp_redirect_wp_redirect">
        <severity>0</severity>
    </rule>

    <!-- Relax strict comparisons and other minor rules -->
    <rule ref="WordPress.PHP.StrictInArray.MissingTrueStrict">
        <severity>0</severity>
    </rule>
    <rule ref="WordPress.WP.I18n.MissingTranslatorsComment">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.PHP.CommentedOutCode.Found">
        <severity>0</severity>
    </rule>
    <rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
        <severity>0</severity>
    </rule>
    <rule ref="Generic.CodeAnalysis.EmptyStatement.DetectedIf">
        <severity>0</severity>
    </rule>
    <rule ref="Universal.ControlStructures.DisallowLonelyIf.Found">
        <severity>0</severity>
    </rule>

    <!-- WordPress Extra rules -->
    <rule ref="WordPress-Extra"/>

    <!-- WordPress Docs rules -->
    <rule ref="WordPress-Docs"/>

    <!-- PHP Compatibility -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>

    <!-- WordPress minimum version -->
    <config name="minimum_wp_version" value="6.0"/>

    <!-- Text domains -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="reforestamos"/>
                <element value="reforestamos-core"/>
                <element value="reforestamos-micrositios"/>
                <element value="reforestamos-comunicacion"/>
                <element value="reforestamos-empresas"/>
            </property>
        </properties>
    </rule>

    <!-- Allow theme-specific file naming -->
    <rule ref="WordPress.Files.FileName">
        <properties>
            <property name="is_theme" value="true"/>
        </properties>
    </rule>
</ruleset>
